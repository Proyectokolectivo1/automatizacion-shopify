{
  "name": "ecommerce-inteligente",
  "version": "0.1.0",
  "private": true,
  "description": "Plataforma interna para automatizar el ciclo operativo de ecommerce.",
  "packageManager": "pnpm@10.25.0",
  "engines": {
    "node": ">=22.16.0 <23",
    "pnpm": "10.25.0"
  },
  "pnpm": {
    "ignoredBuiltDependencies": [
      "msgpackr-extract"
    ],
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "prisma"
    ],
    "overrides": {
      "@hono/node-server": "1.19.13",
      "postcss": "8.5.10"
    }
  },
  "scripts": {
    "build": "turbo run build",
    "auth:verify": "pnpm --filter @ecommerce/api test:auth",
    "database:migrate": "pnpm --filter @ecommerce/api database:migrate",
    "database:status": "pnpm --filter @ecommerce/api database:status",
    "database:verify": "pnpm --filter @ecommerce/api test:database",
    "dlq:verify": "pnpm --filter @ecommerce/api test:dlq",
    "dev": "turbo run dev --parallel",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "infra:bootstrap": "node scripts/bootstrap-local-env.mjs",
    "infra:config": "docker compose config --quiet",
    "infra:down": "docker compose down",
    "infra:up": "docker compose up -d --wait --wait-timeout 180",
    "infra:verify": "node scripts/verify-local-infra.mjs",
    "identity:bootstrap": "pnpm --filter @ecommerce/api bootstrap:owner",
    "identity:verify": "pnpm --filter @ecommerce/api test:identity",
    "lint": "eslint scripts eslint.config.mjs --max-warnings=0 && turbo run lint",
    "observability:verify": "node scripts/verify-observability.mjs",
    "outbox:verify": "pnpm --filter @ecommerce/api test:outbox",
    "prisma:generate": "pnpm --filter @ecommerce/api prisma:generate",
    "shopify:verify": "pnpm --filter @ecommerce/api test:shopify",
    "shopify:webhooks:verify": "pnpm --filter @ecommerce/api test:shopify-webhook",
    "shopify:orders:verify": "pnpm --filter @ecommerce/api test:shopify-order",
    "orders:classification:verify": "pnpm --filter @ecommerce/api test:order-classification",
    "shopify:reconciliation:verify": "pnpm --filter @ecommerce/api test:shopify-reconciliation",
    "transport-rates:verify": "pnpm --filter @ecommerce/api test:transport-rate",
    "wompi:verify": "pnpm --filter @ecommerce/api test:wompi",
    "test": "turbo run test",
    "test:integration": "pnpm --filter @ecommerce/api test:integration",
    "typecheck": "turbo run typecheck",
    "validate": "pnpm prisma:generate && pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm build"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.6",
    "@eslint/js": "9.39.2",
    "@types/node": "22.20.1",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "9.39.2",
    "eslint-config-next": "15.5.20",
    "globals": "16.5.0",
    "prettier": "3.9.5",
    "turbo": "2.10.4",
    "typescript": "5.9.3",
    "typescript-eslint": "8.63.0",
    "vitest": "4.1.10"
  }
}
