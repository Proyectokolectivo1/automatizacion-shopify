generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum StoreStatus {
  PENDING      @map("pending")
  ACTIVE       @map("active")
  DISCONNECTED @map("disconnected")
  SUSPENDED    @map("suspended")

  @@map("store_status")
}

enum IntegrationProvider {
  SHOPIFY        @map("shopify")
  WOMPI          @map("wompi")
  MASTERSHOP     @map("mastershop")
  WHATSAPP       @map("whatsapp")
  META_ADS       @map("meta_ads")
  GOOGLE_ADS     @map("google_ads")
  TIKTOK_ADS     @map("tiktok_ads")
  EMAIL          @map("email")
  OBJECT_STORAGE @map("object_storage")

  @@map("integration_provider")
}

enum IntegrationStatus {
  PENDING  @map("pending")
  TESTED   @map("tested")
  ACTIVE   @map("active")
  DISABLED @map("disabled")
  ERROR    @map("error")

  @@map("integration_status")
}

enum IntegrationHealthStatus {
  UNKNOWN   @map("unknown")
  HEALTHY   @map("healthy")
  UNHEALTHY @map("unhealthy")

  @@map("integration_health_status")
}

enum WhatsAppTemplateCategory {
  AUTHENTICATION @map("authentication")
  MARKETING      @map("marketing")
  UTILITY        @map("utility")

  @@map("whatsapp_template_category")
}

enum WhatsAppTemplateStatus {
  LOCAL_DRAFT        @map("local_draft")
  SIMULATED_APPROVED @map("simulated_approved")
  SIMULATED_REJECTED @map("simulated_rejected")

  @@map("whatsapp_template_status")
}

enum WhatsAppConversationStatus {
  OPEN   @map("open")
  CLOSED @map("closed")

  @@map("whatsapp_conversation_status")
}

enum WhatsAppMessageDirection {
  OUTBOUND @map("outbound")
  INBOUND  @map("inbound")

  @@map("whatsapp_message_direction")
}

enum WhatsAppMessageType {
  TEMPLATE @map("template")
  TEXT     @map("text")

  @@map("whatsapp_message_type")
}

enum WhatsAppMessageStatus {
  SIMULATED_ACCEPTED @map("simulated_accepted")

  @@map("whatsapp_message_status")
}

enum IdempotencyStatus {
  PROCESSING @map("processing")
  COMPLETED  @map("completed")
  FAILED     @map("failed")

  @@map("idempotency_status")
}

enum OutboxStatus {
  PENDING     @map("pending")
  PROCESSING  @map("processing")
  PUBLISHED   @map("published")
  FAILED      @map("failed")
  DEAD_LETTER @map("dead_letter")

  @@map("outbox_status")
}

enum JobExecutionStatus {
  WAITING     @map("waiting")
  ACTIVE      @map("active")
  COMPLETED   @map("completed")
  FAILED      @map("failed")
  DEAD_LETTER @map("dead_letter")

  @@map("job_execution_status")
}

enum WebhookEventStatus {
  RECEIVED    @map("received")
  PROCESSING  @map("processing")
  PROCESSED   @map("processed")
  FAILED      @map("failed")
  DEAD_LETTER @map("dead_letter")

  @@map("webhook_event_status")
}

enum OrderPaymentMode {
  UNCLASSIFIED @map("unclassified")
  PREPAID      @map("prepaid")
  COD          @map("cod")

  @@map("order_payment_mode")
}

enum OrderState {
  RECEIVED                         @map("received")
  VALIDATING                       @map("validating")
  INVALID_DATA                     @map("invalid_data")
  READY_FOR_PAYMENT_CLASSIFICATION @map("ready_for_payment_classification")
  PENDING_TRANSPORT_PAYMENT        @map("pending_transport_payment")
  TRANSPORT_PAYMENT_EXPIRED        @map("transport_payment_expired")
  ABANDONO_PAGO_TRANSPORTE         @map("abandono_pago_transporte")
  READY_FOR_LOGISTICS              @map("ready_for_logistics")
  CANCELLED                        @map("cancelled")
  MANUAL_REVIEW                    @map("manual_review")

  @@map("order_state")
}

enum PaymentIntentStatus {
  PENDING  @map("pending")
  APPROVED @map("approved")
  DECLINED @map("declined")
  EXPIRED  @map("expired")
  VOIDED   @map("voided")
  ERROR    @map("error")

  @@map("payment_intent_status")
}

enum PaymentAbandonmentAction {
  MARK   @map("mark")
  CANCEL @map("cancel")

  @@map("payment_abandonment_action")
}

enum PaymentProviderEventStatus {
  ACCEPTED @map("accepted")
  REJECTED @map("rejected")

  @@map("payment_provider_event_status")
}

enum PaymentReminderStatus {
  SCHEDULED @map("scheduled")
  REQUESTED @map("requested")
  CANCELLED @map("cancelled")

  @@map("payment_reminder_status")
}

enum PaymentReconciliationRunStatus {
  COMPLETED @map("completed")
  FAILED    @map("failed")

  @@map("payment_reconciliation_run_status")
}

enum PaymentReconciliationIssueType {
  INTENT_STATUS_MISMATCH    @map("intent_status_mismatch")
  EVENT_STATUS_MISMATCH     @map("event_status_mismatch")
  MISSING_ACCEPTED_EVENT    @map("missing_accepted_event")
  TRANSACTION_DATA_MISMATCH @map("transaction_data_mismatch")

  @@map("payment_reconciliation_issue_type")
}

enum PaymentReconciliationIssueStatus {
  OPEN     @map("open")
  RESOLVED @map("resolved")

  @@map("payment_reconciliation_issue_status")
}

enum ReconciliationIssueType {
  MISSING_ORDER  @map("missing_order")
  FAILED_WEBHOOK @map("failed_webhook")
  STUCK_ORDER    @map("stuck_order")

  @@map("reconciliation_issue_type")
}

enum ReconciliationIssueStatus {
  OPEN         @map("open")
  REPROCESSING @map("reprocessing")
  RESOLVED     @map("resolved")

  @@map("reconciliation_issue_status")
}

enum AddressValidationStatus {
  UNVALIDATED @map("unvalidated")

  @@map("address_validation_status")
}

enum UserStatus {
  ACTIVE   @map("active")
  DISABLED @map("disabled")

  @@map("user_status")
}

enum MembershipStatus {
  ACTIVE  @map("active")
  REVOKED @map("revoked")

  @@map("membership_status")
}

enum OrganizationRole {
  OWNER      @map("owner")
  ADMIN      @map("admin")
  OPERATIONS @map("operations")
  LOGISTICS  @map("logistics")
  SUPPORT    @map("support")
  FINANCE    @map("finance")
  READ_ONLY  @map("read_only")

  @@map("organization_role")
}

enum AuditOutcome {
  SUCCESS @map("success")
  FAILURE @map("failure")
  DENIED  @map("denied")

  @@map("audit_outcome")
}

enum AccountActionPurpose {
  INVITATION     @map("invitation")
  PASSWORD_RESET @map("password_reset")

  @@map("account_action_purpose")
}

model Organization {
  id                               String                            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                             String                            @db.VarChar(160)
  timezone                         String                            @default("America/Bogota") @db.VarChar(64)
  defaultCurrency                  String                            @default("COP") @map("default_currency") @db.Char(3)
  createdAt                        DateTime                          @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt                        DateTime                          @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(3)
  stores                           Store[]
  memberships                      OrganizationMembership[]
  sessions                         AuthSession[]
  auditLogs                        AuditLog[]
  accountActionTokens              AccountActionToken[]
  outboxEvents                     OutboxEvent[]
  jobExecutions                    JobExecution[]
  integrationConnections           IntegrationConnection[]
  whatsappTemplates                WhatsAppTemplate[]
  whatsappConversations            WhatsAppConversation[]
  whatsappMessages                 WhatsAppMessage[]
  webhookEvents                    WebhookEvent[]
  customers                        Customer[]
  customerAddresses                CustomerAddress[]
  orders                           Order[]
  orderItems                       OrderItem[]
  orderClassificationPolicies      OrderClassificationPolicy[]
  orderStateHistory                OrderStateHistory[]
  transportRatePolicies            TransportRatePolicy[]
  transportRateRules               TransportRateRule[]
  transportRateDecisions           TransportRateDecision[]
  paymentIntents                   PaymentIntent[]
  paymentProviderEvents            PaymentProviderEvent[]
  paymentReminders                 PaymentReminder[]
  paymentReconciliationCheckpoints PaymentReconciliationCheckpoint[]
  paymentReconciliationRuns        PaymentReconciliationRun[]
  paymentReconciliationIssues      PaymentReconciliationIssue[]
  reconciliationCheckpoints        ReconciliationCheckpoint[]
  reconciliationIssues             OrderReconciliationIssue[]

  @@map("organizations")
}

model User {
  id                        String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                     String                   @unique(map: "users_email_key") @db.VarChar(320)
  passwordHash              String                   @map("password_hash") @db.VarChar(512)
  passwordAlgorithm         String                   @default("argon2id-v1") @map("password_algorithm") @db.VarChar(32)
  passwordParametersJson    Json                     @map("password_parameters_json") @db.JsonB
  status                    UserStatus               @default(ACTIVE)
  failedLoginAttempts       Int                      @default(0) @map("failed_login_attempts")
  lockedUntil               DateTime?                @map("locked_until") @db.Timestamptz(3)
  lastLoginAt               DateTime?                @map("last_login_at") @db.Timestamptz(3)
  createdAt                 DateTime                 @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt                 DateTime                 @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(3)
  memberships               OrganizationMembership[]
  sessions                  AuthSession[]
  auditLogs                 AuditLog[]
  accountActionTokens       AccountActionToken[]     @relation("AccountActionSubject")
  issuedAccountActionTokens AccountActionToken[]     @relation("AccountActionIssuer")
  orderStateHistory         OrderStateHistory[]

  @@index([status, lockedUntil], map: "users_status_locked_until_idx")
  @@map("users")
}

model OrganizationMembership {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String           @map("organization_id") @db.Uuid
  userId         String           @map("user_id") @db.Uuid
  role           OrganizationRole
  status         MembershipStatus @default(ACTIVE)
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime         @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(3)
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  user           User             @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([organizationId, userId], map: "organization_memberships_organization_user_key")
  @@index([userId, status], map: "organization_memberships_user_status_idx")
  @@index([organizationId, role, status], map: "organization_memberships_role_status_idx")
  @@map("organization_memberships")
}

model AuthSession {
  id               String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String       @map("user_id") @db.Uuid
  organizationId   String       @map("organization_id") @db.Uuid
  accessTokenHash  String       @unique(map: "auth_sessions_access_token_hash_key") @map("access_token_hash") @db.Char(64)
  refreshTokenHash String       @unique(map: "auth_sessions_refresh_token_hash_key") @map("refresh_token_hash") @db.Char(64)
  accessExpiresAt  DateTime     @map("access_expires_at") @db.Timestamptz(3)
  refreshExpiresAt DateTime     @map("refresh_expires_at") @db.Timestamptz(3)
  refreshVersion   Int          @default(0) @map("refresh_version")
  userAgentHash    String?      @map("user_agent_hash") @db.Char(64)
  ipHash           String?      @map("ip_hash") @db.Char(64)
  lastUsedAt       DateTime?    @map("last_used_at") @db.Timestamptz(3)
  revokedAt        DateTime?    @map("revoked_at") @db.Timestamptz(3)
  createdAt        DateTime     @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt        DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(3)
  user             User         @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([userId, revokedAt, refreshExpiresAt], map: "auth_sessions_user_active_idx")
  @@index([organizationId, revokedAt], map: "auth_sessions_organization_active_idx")
  @@map("auth_sessions")
}

model AuthRateLimit {
  keyHash         String    @id @map("key_hash") @db.Char(64)
  windowStartedAt DateTime  @map("window_started_at") @db.Timestamptz(3)
  attemptCount    Int       @default(0) @map("attempt_count")
  blockedUntil    DateTime? @map("blocked_until") @db.Timestamptz(3)
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([blockedUntil], map: "auth_rate_limits_blocked_until_idx")
  @@map("auth_rate_limits")
}

model AuditLog {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actorUserId    String?       @map("actor_user_id") @db.Uuid
  organizationId String?       @map("organization_id") @db.Uuid
  action         String        @db.VarChar(120)
  outcome        AuditOutcome
  resourceType   String?       @map("resource_type") @db.VarChar(120)
  resourceId     String?       @map("resource_id") @db.VarChar(128)
  correlationId  String        @map("correlation_id") @db.VarChar(128)
  metadataJson   Json          @default("{}") @map("metadata_json") @db.JsonB
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz(3)
  actorUser      User?         @relation(fields: [actorUserId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([actorUserId, createdAt], map: "audit_logs_actor_created_at_idx")
  @@index([organizationId, createdAt], map: "audit_logs_organization_created_at_idx")
  @@index([action, outcome, createdAt], map: "audit_logs_action_outcome_created_at_idx")
  @@index([correlationId], map: "audit_logs_correlation_id_idx")
  @@map("audit_logs")
}

model AccountActionToken {
  id             String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  purpose        AccountActionPurpose
  tokenHash      String               @unique(map: "account_action_tokens_token_hash_key") @map("token_hash") @db.Char(64)
  organizationId String?              @map("organization_id") @db.Uuid
  userId         String?              @map("user_id") @db.Uuid
  invitedEmail   String?              @map("invited_email") @db.VarChar(320)
  invitedRole    OrganizationRole?    @map("invited_role")
  issuedByUserId String?              @map("issued_by_user_id") @db.Uuid
  expiresAt      DateTime             @map("expires_at") @db.Timestamptz(3)
  consumedAt     DateTime?            @map("consumed_at") @db.Timestamptz(3)
  revokedAt      DateTime?            @map("revoked_at") @db.Timestamptz(3)
  createdAt      DateTime             @default(now()) @map("created_at") @db.Timestamptz(3)
  organization   Organization?        @relation(fields: [organizationId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  user           User?                @relation("AccountActionSubject", fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  issuedByUser   User?                @relation("AccountActionIssuer", fields: [issuedByUserId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([organizationId, invitedEmail, purpose, createdAt], map: "account_action_tokens_invitation_idx")
  @@index([userId, purpose, createdAt], map: "account_action_tokens_user_idx")
  @@index([expiresAt, consumedAt, revokedAt], map: "account_action_tokens_lifecycle_idx")
  @@map("account_action_tokens")
}

model Store {
  id                               String                            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId                   String                            @map("organization_id") @db.Uuid
  organization                     Organization                      @relation(fields: [organizationId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  name                             String                            @db.VarChar(160)
  shopifyShopDomain                String                            @unique(map: "stores_shopify_shop_domain_key") @map("shopify_shop_domain") @db.VarChar(255)
  status                           StoreStatus                       @default(PENDING)
  timezone                         String                            @db.VarChar(64)
  currency                         String                            @db.Char(3)
  settingsJson                     Json                              @default("{}") @map("settings_json") @db.JsonB
  createdAt                        DateTime                          @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt                        DateTime                          @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(3)
  integrationConnections           IntegrationConnection[]
  whatsappTemplates                WhatsAppTemplate[]
  whatsappConversations            WhatsAppConversation[]
  whatsappMessages                 WhatsAppMessage[]
  webhookEvents                    WebhookEvent[]
  customers                        Customer[]
  customerAddresses                CustomerAddress[]
  orders                           Order[]
  orderItems                       OrderItem[]
  orderClassificationPolicies      OrderClassificationPolicy[]
  orderStateHistory                OrderStateHistory[]
  transportRatePolicies            TransportRatePolicy[]
  transportRateDecisions           TransportRateDecision[]
  paymentIntents                   PaymentIntent[]
  paymentProviderEvents            PaymentProviderEvent[]
  paymentReminders                 PaymentReminder[]
  paymentReconciliationCheckpoints PaymentReconciliationCheckpoint[]
  paymentReconciliationRuns        PaymentReconciliationRun[]
  paymentReconciliationIssues      PaymentReconciliationIssue[]
  reconciliationCheckpoints        ReconciliationCheckpoint[]
  reconciliationIssues             OrderReconciliationIssue[]

  @@unique([organizationId, id], map: "stores_organization_id_id_key")
  @@index([organizationId, status], map: "stores_organization_status_idx")
  @@index([createdAt], map: "stores_created_at_idx")
  @@map("stores")
}

model IntegrationConnection {
  id                         String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId             String                  @map("organization_id") @db.Uuid
  storeId                    String                  @map("store_id") @db.Uuid
  provider                   IntegrationProvider
  displayName                String                  @map("display_name") @db.VarChar(160)
  status                     IntegrationStatus       @default(PENDING)
  encryptedCredentialsJson   Json                    @map("encrypted_credentials") @db.JsonB
  encryptedWebhookSecretJson Json?                   @map("encrypted_webhook_secret") @db.JsonB
  configJson                 Json                    @default("{}") @map("config_json") @db.JsonB
  lastHealthCheckAt          DateTime?               @map("last_health_check_at") @db.Timestamptz(3)
  lastHealthStatus           IntegrationHealthStatus @default(UNKNOWN) @map("last_health_status")
  credentialRotatedAt        DateTime?               @map("credential_rotated_at") @db.Timestamptz(3)
  createdAt                  DateTime                @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt                  DateTime                @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(3)
  organization               Organization            @relation(fields: [organizationId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  store                      Store                   @relation(fields: [organizationId, storeId], references: [organizationId, id], onDelete: Restrict, onUpdate: Cascade, map: "integration_connections_store_tenant_fkey")

  @@unique([storeId, provider], map: "integration_connections_store_provider_key")
  @@index([organizationId, provider, status], map: "integration_connections_organization_provider_status_idx")
  @@index([status, lastHealthCheckAt], map: "integration_connections_health_idx")
  @@map("integration_connections")
}

model WhatsAppTemplate {
  id                  String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId      String                   @map("organization_id") @db.Uuid
  storeId             String                   @map("store_id") @db.Uuid
  templateKey         String                   @map("template_key") @db.Uuid
  version             Int
  name                String                   @db.VarChar(120)
  metaTemplateName    String                   @map("meta_template_name") @db.VarChar(512)
  languageCode        String                   @map("language_code") @db.VarChar(16)
  category            WhatsAppTemplateCategory
  status              WhatsAppTemplateStatus   @default(LOCAL_DRAFT)
  bodyTemplate        String                   @map("body_template") @db.VarChar(4096)
  variablesSchemaJson Json                     @map("variables_schema_json") @db.JsonB
  eventType           String                   @map("event_type") @db.VarChar(160)
  active              Boolean                  @default(false)
  statusReasonCode    String?                  @map("status_reason_code") @db.VarChar(80)
  reviewedAt          DateTime?                @map("reviewed_at") @db.Timestamptz(3)
  createdAt           DateTime                 @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt           DateTime                 @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(3)
  organization        Organization             @relation(fields: [organizationId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  store               Store                    @relation(fields: [organizationId, storeId], references: [organizationId, id], onDelete: Restrict, onUpdate: Cascade, map: "whatsapp_templates_store_tenant_fkey")
  messages            WhatsAppMessage[]

  @@unique([templateKey, version], map: "whatsapp_templates_key_version_key")
  @@unique([storeId, metaTemplateName, languageCode, version], map: "whatsapp_templates_store_meta_language_version_key")
  @@unique([organizationId, storeId, id], map: "whatsapp_templates_organization_store_id_key")
  @@index([organizationId, storeId, createdAt], map: "whatsapp_templates_tenant_created_idx")
  @@index([storeId, eventType, languageCode, status], map: "whatsapp_templates_event_language_status_idx")
  @@map("whatsapp_templates")
}

model WhatsAppConversation {
  id             String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String                     @map("organization_id") @db.Uuid
  storeId        String                     @map("store_id") @db.Uuid
  customerId     String                     @map("customer_id") @db.Uuid
  phoneE164      String                     @map("phone_e164") @db.VarChar(32)
  status         WhatsAppConversationStatus @default(OPEN)
  lastMessageAt  DateTime                   @map("last_message_at") @db.Timestamptz(3)
  createdAt      DateTime                   @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime                   @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(3)
  organization   Organization               @relation(fields: [organizationId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  store          Store                      @relation(fields: [organizationId, storeId], references: [organizationId, id], onDelete: Restrict, onUpdate: Cascade, map: "whatsapp_conversations_store_tenant_fkey")
  customer       Customer                   @relation(fields: [organizationId, storeId, customerId], references: [organizationId, storeId, id], onDelete: Restrict, onUpdate: Cascade, map: "whatsapp_conversations_customer_tenant_fkey")
  messages       WhatsAppMessage[]

  @@unique([storeId, phoneE164], map: "whatsapp_conversations_store_phone_key")
  @@unique([organizationId, storeId, id], map: "whatsapp_conversations_tenant_id_key")
  @@index([organizationId, status, lastMessageAt], map: "whatsapp_conversations_tenant_status_last_idx")
  @@index([customerId, lastMessageAt], map: "whatsapp_conversations_customer_last_idx")
  @@map("whatsapp_conversations")
}

model WhatsAppMessage {
  id                    String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId        String                   @map("organization_id") @db.Uuid
  storeId               String                   @map("store_id") @db.Uuid
  conversationId        String                   @map("conversation_id") @db.Uuid
  orderId               String                   @map("order_id") @db.Uuid
  templateId            String                   @map("template_id") @db.Uuid
  direction             WhatsAppMessageDirection @default(OUTBOUND)
  providerMessageId     String                   @unique(map: "whatsapp_messages_provider_message_key") @map("provider_message_id") @db.VarChar(160)
  type                  WhatsAppMessageType      @default(TEMPLATE)
  status                WhatsAppMessageStatus    @default(SIMULATED_ACCEPTED)
  body                  String                   @db.VarChar(4096)
  metadataJson          Json                     @map("metadata_json") @db.JsonB
  businessKeyHash       String                   @unique(map: "whatsapp_messages_business_key_hash_key") @map("business_key_hash") @db.Char(64)
  requestFingerprint    String                   @map("request_fingerprint") @db.Char(64)
  sentAt                DateTime?                @map("sent_at") @db.Timestamptz(3)
  deliveredAt           DateTime?                @map("delivered_at") @db.Timestamptz(3)
  readAt                DateTime?                @map("read_at") @db.Timestamptz(3)
  failedAt              DateTime?                @map("failed_at") @db.Timestamptz(3)
  createdAt             DateTime                 @default(now()) @map("created_at") @db.Timestamptz(3)
  organization          Organization             @relation(fields: [organizationId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  store                 Store                    @relation(fields: [organizationId, storeId], references: [organizationId, id], onDelete: Restrict, onUpdate: Cascade, map: "whatsapp_messages_store_tenant_fkey")
