NODE_ENV=development
API_HOST=127.0.0.1
API_PORT=3001
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
LOG_LEVEL=info
DEPENDENCY_TIMEOUT_MS=1500
AUTH_ACCESS_TTL_SECONDS=900
AUTH_REFRESH_TTL_SECONDS=2592000
AUTH_ACCOUNT_ACTIONS_ENABLED=false
AUTH_ACCOUNT_ACTIONS_KILL_SWITCH=true
AUTH_INVITATION_TTL_SECONDS=86400
AUTH_PASSWORD_RESET_TTL_SECONDS=1800
AUTH_LOGIN_MAX_ATTEMPTS=5
AUTH_RATE_WINDOW_MS=60000
AUTH_BLOCK_DURATION_MS=300000
EMAIL_DELIVERY_ENABLED=false
EMAIL_KILL_SWITCH=true
EMAIL_SIMULATION_MODE=true
IDENTITY_ADMIN_ENABLED=false
IDENTITY_ADMIN_KILL_SWITCH=true
IDENTITY_BOOTSTRAP_ENABLED=false
IDENTITY_BOOTSTRAP_KILL_SWITCH=true
# Solo para `pnpm identity:bootstrap`; suministrar por entorno local y retirar al finalizar.
# IDENTITY_BOOTSTRAP_SECRET=
# IDENTITY_BOOTSTRAP_EMAIL=
# IDENTITY_BOOTSTRAP_PASSWORD=
# IDENTITY_BOOTSTRAP_ORGANIZATION_NAME=
SHOPIFY_INTEGRATIONS_ENABLED=false
SHOPIFY_INTEGRATIONS_KILL_SWITCH=true
SHOPIFY_SIMULATION_MODE=true
SHOPIFY_WEBHOOKS_ENABLED=false
SHOPIFY_WEBHOOKS_KILL_SWITCH=true
SHOPIFY_WEBHOOKS_SIMULATION_MODE=true
SHOPIFY_WEBHOOKS_MAX_BODY_BYTES=262144
SHOPIFY_ORDER_SYNC_ENABLED=false
SHOPIFY_ORDER_SYNC_KILL_SWITCH=true
SHOPIFY_ORDER_SYNC_SIMULATION_MODE=true
ORDER_CLASSIFICATION_ENABLED=false
ORDER_CLASSIFICATION_KILL_SWITCH=true
ORDER_CLASSIFICATION_SIMULATION_MODE=true
TRANSPORT_RATES_ENABLED=false
TRANSPORT_RATES_KILL_SWITCH=true
TRANSPORT_RATES_SIMULATION_MODE=true
WOMPI_ENABLED=false
WOMPI_KILL_SWITCH=true
WOMPI_SIMULATION_MODE=true
WOMPI_PAYMENT_LINK_TTL_MINUTES=1440
WOMPI_WEBHOOKS_ENABLED=false
WOMPI_WEBHOOKS_KILL_SWITCH=true
WOMPI_WEBHOOKS_MAX_BODY_BYTES=262144
WOMPI_WEBHOOKS_MAX_SKEW_SECONDS=300
PAYMENT_REMINDERS_ENABLED=false
PAYMENT_REMINDERS_KILL_SWITCH=true
PAYMENT_REMINDERS_SIMULATION_MODE=true
PAYMENT_REMINDERS_POLL_INTERVAL_MS=60000
PAYMENT_REMINDERS_BATCH_SIZE=50
PAYMENT_EXPIRATION_ENABLED=false
PAYMENT_EXPIRATION_KILL_SWITCH=true
PAYMENT_EXPIRATION_SIMULATION_MODE=true
PAYMENT_EXPIRATION_DEFAULT_ACTION=MARK
PAYMENT_EXPIRATION_POLL_INTERVAL_MS=60000
PAYMENT_EXPIRATION_BATCH_SIZE=50
WOMPI_RECONCILIATION_ENABLED=false
WOMPI_RECONCILIATION_KILL_SWITCH=true
WOMPI_RECONCILIATION_SIMULATION_MODE=true
WOMPI_RECONCILIATION_POLL_INTERVAL_MS=300000
WOMPI_RECONCILIATION_INTERVAL_HOURS=24
WOMPI_RECONCILIATION_LOOKBACK_HOURS=24
WOMPI_RECONCILIATION_BATCH_SIZE=25
WHATSAPP_INTEGRATIONS_ENABLED=false
WHATSAPP_INTEGRATIONS_KILL_SWITCH=true
WHATSAPP_SIMULATION_MODE=true
WHATSAPP_TEMPLATES_ENABLED=false
WHATSAPP_TEMPLATES_KILL_SWITCH=true
WHATSAPP_TEMPLATES_SIMULATION_MODE=true
SHOPIFY_RECONCILIATION_ENABLED=false
SHOPIFY_RECONCILIATION_KILL_SWITCH=true
SHOPIFY_RECONCILIATION_MAX_WINDOW_HOURS=24
SHOPIFY_RECONCILIATION_SIMULATION_MODE=true
SHOPIFY_RECONCILIATION_STUCK_AFTER_MINUTES=15
# Claves AES-256-GCM versionadas, solo por secret manager/entorno; nunca confirmar valores reales.
# SHOPIFY_CREDENTIAL_KEY_VERSION=v1
# SHOPIFY_CREDENTIAL_KEYS_JSON={"v1":"base64url-de-32-bytes"}
# WHATSAPP_CREDENTIAL_KEY_VERSION=v1
# WHATSAPP_CREDENTIAL_KEYS_JSON={"v1":"base64url-de-32-bytes"}
OUTBOX_PUBLISHER_ENABLED=false
OUTBOX_KILL_SWITCH=true
OUTBOX_SIMULATION_MODE=true
OUTBOX_OPERATIONS_ENABLED=false
OUTBOX_OPERATIONS_KILL_SWITCH=true
OUTBOX_QUEUE_NAME=foundation-events
OUTBOX_DLQ_NAME=dead-letter
OUTBOX_BATCH_SIZE=25
OUTBOX_LEASE_MS=30000
OUTBOX_MAX_ATTEMPTS=5
OUTBOX_POLL_INTERVAL_MS=1000
OUTBOX_RETRY_BASE_MS=1000

# Infraestructura local. Ejecute `pnpm infra:bootstrap`; no use estos campos vacíos directamente.
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5433
POSTGRES_DB=ecommerce
POSTGRES_USER=ecommerce
POSTGRES_PASSWORD=
REDIS_HOST=127.0.0.1
REDIS_PORT=6380
REDIS_PASSWORD=
MINIO_HOST=127.0.0.1
MINIO_API_PORT=9100
MINIO_CONSOLE_PORT=9101
MINIO_ROOT_USER=ecommerce_local
MINIO_ROOT_PASSWORD=
MINIO_BUCKET=ecommerce-documents
MINIO_USE_SSL=false
